// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

enum Language {
  EN
  ZH
  JP
  KR
}

enum TxFlowType {
  DEPOSIT
  WITHDRAW
  PURCHASE
  EQUITY
}

enum TxFlowStatus {
  PENDING
  CONFIRMED
  FAILED
  ABORT
  AUDITING
  REFUSED
}

enum TokenType {
  USDT
  HAK
}

enum UserType {
  NORMAL
  COMMUNITY
}

enum EquityType {
  BASE
  PLUS
  PREMIUM
}

model User {
  id            String    @id @default(cuid())
  walletAddress String    @unique @db.VarChar(255) @map("wallet_address")
  username      String?    @unique @db.VarChar(255)
  displayName   String?    @db.VarChar(255) @map("display_name")
  gender        Gender?
  bio           String?   @db.VarChar(255)
  email         String?   @db.VarChar(255)
  phoneNumber   String?   @db.VarChar(255) @map("phone_number")
  darkMode      Boolean   @default(false) @map("dark_mode")
  language      Language  @default(EN)
  portraitUrl   String?   @db.VarChar(255) @map("portrait_url")
  avatarUrl     String?   @db.VarChar(255) @map("avatar_url")
  backgroundUrl String?   @db.VarChar(255) @map("background_url")
  type          UserType?
  path          String?  // Materialized path storing the hierarchy path
  equityType    EquityType? @map("equity_type")
  superior      String?   @db.VarChar(255)// Superior's Solana wallet address
  referralCode String?   @db.VarChar(255) @map("referral_code") @unique
  purchaseAt    DateTime?
  equityActivedAt      DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([walletAddress])
  @@index([username])
  @@index([email])
  @@index([phoneNumber])
  @@map("user")
}

model UserStatistic {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  postCount     Int       @default(0) @map("post_count")
  followerCount Int       @default(0) @map("follower_count")
  followingCount Int       @default(0) @map("following_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_statistic")
}

enum LinkedPlatform {
  DISCORD
  X
  TELEGRAM
  INSTAGRAM
}

model UserLinkedAccount {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  linkedPlatform LinkedPlatform    @map("linked_platform")
  account String    @map("account")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_linked_account")
}

model Post {
  id            String    @id @default(cuid())
  rePostId      String?   @map("re_post_id")
  userId        String    @map("user_id")
  title         String?   @db.VarChar(255)
  content       String?   @db.VarChar(10000)
  published     Boolean   @default(false)
  mediaUrls     String[]  @map("media_urls")
  mentionedUserIds String[] @map("mentioned_user_ids")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([userId])

  @@map("post")
}

model PostStatistic {
  postId        String    @id @map("post_id")
  viewCount     Int       @default(0) @map("view_count")
  likeCount     Int       @default(0) @map("like_count")
  commentCount  Int       @default(0) @map("comment_count")
  repostCount   Int       @default(0) @map("repost_count")

  @@index([postId])

  @@map("post_statistic")
}

model Comment {
  id              String    @id @default(cuid())
  postId          String    @map("post_id")
  userId          String    @map("user_id")
  replyUserId     String?   @map("reply_user_id")
  content         String    @db.VarChar(10000)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([postId])
  @@index([userId])
  @@index([replyUserId])

  @@map("comment")
}

model CommentStatistic {
  commentId       String    @id @map("comment_id")
  viewCount       Int       @default(0) @map("view_count")
  likeCount       Int       @default(0) @map("like_count")
  repostCount     Int       @default(0) @map("repost_count")

  @@index([commentId])

  @@map("comment_statistic")
}

model PostLike {
  id              String    @id @default(cuid())
  postId          String    @map("post_id")
  userId          String    @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([userId])
  @@index([postId])
  @@map("post_like")
}

model CommentLike {
  id              String    @id @default(cuid())
  commentId       String    @map("comment_id")
  userId          String    @map("user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([userId])
  @@index([commentId])
  @@map("comment_like")
}

model Follow {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  followingUserId String    @map("following_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([userId])
  @@index([followingUserId])
  @@map("follow")
}

enum NotificationType {
  MENTIONED
  COMMENT
  FOLLOW
}

model Notification {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  resourceId      String    @map("resource_id")
  notificationType NotificationType    @map("notification_type")
  readAt          DateTime? @map("read_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([userId])
  @@map("notification")
}

model Message {
  id              String    @id @default(cuid())
  sendUserId      String    @map("send_user_id")
  receiveUserId   String    @map("receive_user_id")
  content         String    @db.VarChar(10000)
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([sendUserId])
  @@index([receiveUserId])
  @@map("message")
}

model Transaction {
  id            String    @id @default(cuid())
  txHash        String?    @map("tx_hash")
  fromAddress   String     @map("from_address")
  toAddress     String     @map("to_address")
  type          TxFlowType
  tokenType     TokenType  @map("token_type") // Type of token (USDT or TXT) @default(TXT)
  amount        Decimal
  amountFee     Decimal?    @map("amount_fee")
  txFee         Decimal?    @map("tx_fee")
  status        TxFlowStatus @default(PENDING)
  description   String?      // Optional description of the transaction
  error         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@map("transaction")
}

model Config {
  key   String @id @unique
  value String

  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  @@map("config")
}
  